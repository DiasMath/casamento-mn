{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!assets/|favicon\\.svg|favicon\\.ico|og-image\\.svg|manifest\\.json|robots\\.txt).*)",
      "destination": "/index.html"
    }
  ]
}
